# Postgres (shared instance, one schema per backend service)
POSTGRES_USER=euro
POSTGRES_PASSWORD=changeme
POSTGRES_DB=euro_platform
POSTGRES_PORT=5432

# euro-auth
JWT_SECRET=changeme-super-secret

# Copy this file to .env and fill in real values before running docker compose.
# AUTH_SERVICE_URL is not listed here: it's set inside docker-compose.yml since
# it points at the internal Docker network hostname (http://euro-auth:3000),
# not something you configure per environment locally.
